.dialog-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(7, 8, 11, 0.66);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.dialog-panel {
  width: 100%;
  max-width: 640rpx;
  border-radius: 28rpx;
  background: linear-gradient(160deg, #23262e 0%, #191b22 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  box-shadow: 0 24rpx 56rpx rgba(0, 0, 0, 0.5);
  overflow: hidden;
}

.dialog-title {
  padding: 42rpx 42rpx 14rpx;
  text-align: center;
  font-size: 38rpx;
  font-weight: 700;
  color: #f4f6fb;
}

.dialog-content {
  padding: 0 42rpx 36rpx;
  text-align: center;
  font-size: 28rpx;
  line-height: 1.68;
  color: #c2c8d5;
  white-space: pre-line;
}

.dialog-actions {
  display: flex;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.dialog-actions.one .btn {
  width: 100%;
}

.dialog-actions.two .btn {
  width: 50%;
}

.btn {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #e8ecf7;
  transition: background-color 120ms ease, opacity 120ms ease;
}

.btn:active {
  opacity: 0.88;
  background: rgba(255, 255, 255, 0.1);
}

.btn.cancel {
  color: #a9b1c0;
  border-right: 1rpx solid rgba(255, 255, 255, 0.1);
}

.dialog-actions.one .btn.cancel {
  border-right: 0;
}

.btn.confirm {
  color: #dbe1ee;
  font-weight: 600;
}

.btn.confirm.danger {
  color: #ff7f7f;
}
