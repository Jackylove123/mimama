.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1b1c20, #121317 58%);
  padding: 88rpx 34rpx calc(44rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.hero {
  min-height: 42vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.logo-shell {
  width: 140rpx;
  height: 140rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.04) 62%, rgba(255, 255, 255, 0));
  box-shadow: 0 18rpx 48rpx rgba(0, 0, 0, 0.22);
}

.logo-image {
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  display: block;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  box-shadow: 0 0 0 2rpx rgba(255, 255, 255, 0.12), 0 14rpx 30rpx rgba(0, 0, 0, 0.3);
}

.brand-title-image {
  margin-top: 28rpx;
  width: 288rpx;
  display: block;
}

.entry-card {
  margin-top: 8rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.05);
  overflow: hidden;
}

.entry-row {
  height: 96rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.entry-row-divider {
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.entry-title {
  color: #e3e6ee;
  font-size: 28rpx;
}

.entry-value {
  color: #9ca3b1;
  font-size: 26rpx;
}

.entry-value-wrap {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.entry-chevron {
  color: #8f96a6;
  font-size: 30rpx;
  line-height: 1;
}
