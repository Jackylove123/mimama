.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1b1c20, #121317 58%);
  padding: 88rpx 34rpx calc(44rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.hero {
  min-height: 42vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.logo-image {
  width: 84rpx;
  height: 84rpx;
  border-radius: 21rpx;
  display: block;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  box-shadow: 0 0 0 2rpx rgba(255, 255, 255, 0.12), 0 14rpx 30rpx rgba(0, 0, 0, 0.3);
}

.brand-name {
  margin-top: 22rpx;
  color: #f7f8fb;
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.entry-card {
  margin-top: 8rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.05);
  overflow: hidden;
}

.entry-row {
  height: 96rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.entry-row-divider {
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.entry-title {
  color: #e3e6ee;
  font-size: 28rpx;
}

.entry-value {
  color: #9ca3b1;
  font-size: 26rpx;
}

.entry-chevron {
  color: #8f96a6;
  font-size: 30rpx;
  line-height: 1;
}
