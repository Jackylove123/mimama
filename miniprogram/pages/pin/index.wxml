<view class="page">
  <block wx:if="{{singlePageMode}}">
    <timeline-landing />
  </block>

  <block wx:else>
  <view class="brand">
    <view class="brand-row">
      <image class="logo-image" src="/assets/mimama-logo.png" mode="aspectFill" />
      <image class="brand-title-image" src="/assets/mimama-title-pin.png" mode="widthFix" />
    </view>
    <view class="brand-tagline">密码只存本地，更安心</view>
  </view>

  <view class="card">
    <view class="title">{{title}}</view>
    <view wx:if="{{tips}}" class="tips">{{tips}}</view>

    <view class="dots">
      <view wx:for="{{pinSlots}}" wx:key="*this" class="dot {{index < digits.length ? 'filled' : ''}}"></view>
    </view>

    <view wx:if="{{cooldownSeconds > 0}}" class="cooldown">暗号输错过多，{{cooldownSeconds}} 秒后再试</view>
    <view class="warning">忘记暗号就无法找回，只能重置本机数据。</view>
  </view>

  <view class="keypad">
    <view wx:for="{{keypadRows}}" wx:key="index" class="row">
      <view
        wx:for="{{item}}"
        wx:key="*this"
        class="key {{item === '' ? 'empty' : ''}}"
        data-key="{{item}}"
        bindtap="onTapKey"
        hover-class="{{item ? 'pressable-active' : ''}}"
        hover-start-time="0"
        hover-stay-time="28"
      >
        <text wx:if="{{item === 'del'}}">删除</text>
        <text wx:elif="{{item}}">{{item}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{creating && setupStep === 2}}" class="reset-first" bindtap="onResetFirstRound" hover-class="pressable-active" hover-start-time="0" hover-stay-time="28">
    重置第一轮输入
  </view>

  <view class="footer-note">删除小程序、清理微信数据或更换设备，未备份数据会永久丢失。</view>

  <app-dialog
    visible="{{dialog.visible}}"
    title="{{dialog.title}}"
    content="{{dialog.content}}"
    showCancel="{{dialog.showCancel}}"
    cancelText="{{dialog.cancelText}}"
    confirmText="{{dialog.confirmText}}"
    danger="{{dialog.danger}}"
    bindconfirm="onDialogConfirm"
    bindcancel="onDialogCancel"
  />

  <view wx:if="{{showPrivacyPopup}}" class="privacy-mask">
    <view class="privacy-panel" catchtap="noop">
      <view class="privacy-title">隐私保护提示</view>
      <view class="privacy-desc">
        为保障功能正常使用，请先阅读并同意{{privacyContractName}}。
      </view>
      <view class="privacy-link" bindtap="onTapPrivacyContract" hover-class="pressable-active" hover-start-time="0" hover-stay-time="28">
        查看隐私协议
      </view>

      <view class="privacy-actions">
        <view class="privacy-btn ghost" bindtap="onRejectPrivacy" hover-class="pressable-active" hover-start-time="0" hover-stay-time="28">暂不使用</view>
        <button
          class="privacy-btn solid"
          open-type="{{privacyNeedOfficialAuth ? 'agreePrivacyAuthorization' : ''}}"
          bindtap="onAgreePrivacyTap"
          bindagreeprivacyauthorization="onAgreePrivacyAuthorization"
          hover-class="light-press-active"
          hover-start-time="0"
          hover-stay-time="28"
        >
          同意并继续
        </button>
      </view>
    </view>
  </view>
  </block>
</view>
