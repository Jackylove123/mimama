<view class="page">
  <view class="brand">
    <image class="logo-image" src="/assets/mimama-logo.png" mode="aspectFill" />
    <view class="brand-name mimama-misans">密麻麻</view>
  </view>

  <view class="card">
    <view class="title">{{title}}</view>
    <view class="tips">{{tips}}</view>

    <view class="dots">
      <view wx:for="{{pinSlots}}" wx:key="*this" class="dot {{index < digits.length ? 'filled' : ''}}"></view>
    </view>

    <view wx:if="{{cooldownSeconds > 0}}" class="cooldown">冷却中，请 {{cooldownSeconds}} 秒后重试</view>
    <view class="warning">遗忘启动暗号将无法找回，只能重置本地数据。</view>
  </view>

  <view class="keypad">
    <view wx:for="{{keypadRows}}" wx:key="index" class="row">
      <view
        wx:for="{{item}}"
        wx:key="*this"
        class="key {{item === '' ? 'empty' : ''}}"
        data-key="{{item}}"
        bindtap="onTapKey"
        hover-class="{{item ? 'pressable-active' : ''}}"
        hover-start-time="0"
        hover-stay-time="28"
      >
        <text wx:if="{{item === 'del'}}">删除</text>
        <text wx:elif="{{item}}">{{item}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{creating && setupStep === 2}}" class="reset-first" bindtap="onResetFirstRound" hover-class="pressable-active" hover-start-time="0" hover-stay-time="28">
    重置第一轮输入
  </view>

  <view class="footer-note">删除小程序、清理微信数据或更换设备，未备份内容可能永久丢失。</view>

  <app-dialog
    visible="{{dialog.visible}}"
    title="{{dialog.title}}"
    content="{{dialog.content}}"
    showCancel="{{dialog.showCancel}}"
    cancelText="{{dialog.cancelText}}"
    confirmText="{{dialog.confirmText}}"
    danger="{{dialog.danger}}"
    bindconfirm="onDialogConfirm"
    bindcancel="onDialogCancel"
  />
</view>
