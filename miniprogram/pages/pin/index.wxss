.page {
  position: relative;
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 18vh) 32rpx calc(32rpx + env(safe-area-inset-bottom));
  background: linear-gradient(160deg, #1b1c20, #121317 58%);
  box-sizing: border-box;
}

.brand {
  margin-bottom: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.brand-row {
  display: flex;
  align-items: center;
}

.logo-image {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  overflow: hidden;
  display: block;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  box-shadow: 0 0 0 2rpx rgba(255, 255, 255, 0.12), 0 12rpx 26rpx rgba(0, 0, 0, 0.35);
}

.brand-title-image {
  margin-left: 2rpx;
  width: 224rpx;
  display: block;
}

.brand-tagline {
  margin-top: 8rpx;
  color: #bcc3d0;
  width: 314rpx;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.25;
  text-align: left;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card {
  background: rgba(255, 255, 255, 0.04);
  border-radius: 24rpx;
  padding: 44rpx 36rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(8rpx);
  box-shadow: 0 16rpx 42rpx rgba(0, 0, 0, 0.22);
}

.title {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 600;
}

.tips {
  margin-top: 12rpx;
  color: #b9beca;
  font-size: 26rpx;
}

.dots {
  margin-top: 40rpx;
  display: flex;
  justify-content: space-between;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 2rpx solid #6f7583;
  background: transparent;
}

.dot.filled {
  border-color: #ffffff;
  background: #ffffff;
}

.cooldown {
  margin-top: 20rpx;
  color: #ff7b7b;
  font-size: 24rpx;
}

.warning {
  margin-top: 18rpx;
  color: #9aa0ad;
  font-size: 22rpx;
}

.timeline-landing .title {
  font-size: 56rpx;
  line-height: 1.25;
}

.timeline-landing .tips {
  margin-top: 24rpx;
  color: #b5bcc8;
  font-size: 28rpx;
  line-height: 1.7;
}

.timeline-divider {
  margin-top: 34rpx;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.09);
}

.timeline-tip {
  margin-top: 34rpx;
  color: #3f84ff;
  font-size: 31rpx;
  font-weight: 600;
  line-height: 1.62;
}

.timeline-trust-row {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
}

.timeline-trust-icon {
  margin-right: 12rpx;
  color: #989fad;
  font-size: 26rpx;
  line-height: 1;
}

.timeline-trust {
  color: #a8b0bf;
  font-size: 24rpx;
  line-height: 1.6;
}

.keypad {
  margin-top: 48rpx;
}

.row {
  display: flex;
  margin-bottom: 20rpx;
}

.key {
  flex: 1;
  margin: 0 10rpx;
  height: 92rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  justify-content: center;
  align-items: center;
  color: #f5f6fa;
  font-size: 32rpx;
  transition: transform 120ms ease, background-color 120ms ease, border-color 120ms ease;
}

.key.empty {
  opacity: 0;
}

.key-active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.14);
  border-color: rgba(255, 255, 255, 0.24);
}

.footer-note {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(env(safe-area-inset-bottom) + 30px);
  color: #ff6b6b;
  font-size: 22rpx;
  line-height: 1.6;
  text-align: left;
}

.reset-first {
  margin-top: 12rpx;
  text-align: center;
  color: #c7ccd8;
  font-size: 24rpx;
  text-decoration: underline;
}

.privacy-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  background: rgba(0, 0, 0, 0.62);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 34rpx;
  box-sizing: border-box;
}

.privacy-panel {
  width: 100%;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: linear-gradient(160deg, rgba(31, 32, 38, 0.98), rgba(21, 22, 27, 0.98));
  box-shadow: 0 20rpx 48rpx rgba(0, 0, 0, 0.34);
  padding: 32rpx 28rpx 26rpx;
  box-sizing: border-box;
}

.privacy-title {
  color: #f8fafc;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.privacy-desc {
  margin-top: 14rpx;
  color: #c7ceda;
  font-size: 26rpx;
  line-height: 1.75;
}

.privacy-link {
  margin-top: 18rpx;
  color: #77d2ff;
  font-size: 25rpx;
  line-height: 1.4;
  display: inline-flex;
  align-items: center;
}

.privacy-actions {
  margin-top: 26rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.privacy-btn {
  flex: 1;
  height: 82rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-sizing: border-box;
}

.privacy-btn.ghost {
  color: #c7ceda;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.06);
}

.privacy-btn.solid {
  margin: 0;
  border: 0;
  color: #1a1d25;
  font-weight: 700;
  background: linear-gradient(145deg, #f6f7fb 0%, #e5e8f0 100%);
  -webkit-appearance: none;
}

.privacy-btn.solid::after {
  border: 0;
}
