.page {
  position: relative;
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 18vh) 32rpx calc(32rpx + env(safe-area-inset-bottom));
  background: linear-gradient(160deg, #1b1c20, #121317 58%);
  box-sizing: border-box;
}

.brand {
  margin-bottom: 22rpx;
  display: flex;
  align-items: center;
}

.logo-image {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  overflow: hidden;
  display: block;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  box-shadow: 0 0 0 2rpx rgba(255, 255, 255, 0.12), 0 12rpx 26rpx rgba(0, 0, 0, 0.35);
}

.brand-name {
  margin-left: 14rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #f5f6fa;
}

.card {
  background: rgba(255, 255, 255, 0.04);
  border-radius: 24rpx;
  padding: 44rpx 36rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(8rpx);
}

.title {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 600;
}

.tips {
  margin-top: 12rpx;
  color: #b9beca;
  font-size: 26rpx;
}

.dots {
  margin-top: 40rpx;
  display: flex;
  justify-content: space-between;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 2rpx solid #6f7583;
  background: transparent;
}

.dot.filled {
  border-color: #ffffff;
  background: #ffffff;
}

.cooldown {
  margin-top: 20rpx;
  color: #ff7b7b;
  font-size: 24rpx;
}

.warning {
  margin-top: 18rpx;
  color: #9aa0ad;
  font-size: 22rpx;
}

.keypad {
  margin-top: 48rpx;
}

.row {
  display: flex;
  margin-bottom: 20rpx;
}

.key {
  flex: 1;
  margin: 0 10rpx;
  height: 92rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  justify-content: center;
  align-items: center;
  color: #f5f6fa;
  font-size: 32rpx;
  transition: transform 120ms ease, background-color 120ms ease, border-color 120ms ease;
}

.key.empty {
  opacity: 0;
}

.key-active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.14);
  border-color: rgba(255, 255, 255, 0.24);
}

.footer-note {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(env(safe-area-inset-bottom) + 30px);
  color: #ff6b6b;
  font-size: 22rpx;
  line-height: 1.6;
  text-align: left;
}

.reset-first {
  margin-top: 12rpx;
  text-align: center;
  color: #c7ccd8;
  font-size: 24rpx;
  text-decoration: underline;
}
