.page {
  min-height: 100vh;
  padding: 40rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  background: linear-gradient(160deg, #1b1c20, #121317 58%);
  box-sizing: border-box;
}

.card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 28rpx;
}

.title {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
}

.tips {
  margin-top: 10rpx;
  color: #bcc2cf;
  font-size: 25rpx;
}

.dots {
  margin-top: 34rpx;
  display: flex;
  justify-content: space-between;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 2rpx solid #6f7583;
}

.dot.filled {
  border-color: #ffffff;
  background: #ffffff;
}

.cooldown {
  margin-top: 16rpx;
  color: #ff8e8e;
  font-size: 24rpx;
}

.keypad {
  margin-top: 42rpx;
}

.row {
  display: flex;
  margin-bottom: 16rpx;
}

.key {
  flex: 1;
  margin: 0 8rpx;
  height: 88rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  justify-content: center;
  align-items: center;
  color: #f5f6fa;
  font-size: 32rpx;
}

.key.empty {
  opacity: 0;
}

.reset-first {
  margin-top: 12rpx;
  text-align: center;
  color: #c7ccd8;
  font-size: 24rpx;
  text-decoration: underline;
}
