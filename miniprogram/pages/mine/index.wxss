.page {
  min-height: 100vh;
  background: #f6f8fa;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border: 1rpx solid #e3e8ef;
  border-radius: 18rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
}

.title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.item {
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 8rpx;
}

.value {
  color: #176b87;
  font-weight: 600;
}

.hint {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #64748b;
  background: #f1f5f9;
  border-radius: 12rpx;
  padding: 12rpx;
}

.button {
  margin-top: 10rpx;
  height: 72rpx;
  border-radius: 14rpx;
  background: #176b87;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.button.ghost {
  background: rgba(23, 107, 135, 0.08);
  color: #176b87;
}

.textarea {
  min-height: 240rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e3e8ef;
  padding: 12rpx;
  font-size: 24rpx;
  color: #0f172a;
  width: 100%;
  box-sizing: border-box;
}

.row {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
}

.half {
  width: 48%;
  height: 72rpx;
  border-radius: 14rpx;
  background: rgba(23, 107, 135, 0.08);
  color: #176b87;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}
