.page {
  min-height: 100vh;
  height: 100vh;
  background: linear-gradient(160deg, #1b1c20, #121317 58%);
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 2px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.content-scroll {
  flex: 1;
  min-height: 0;
}

.content-inner {
  box-sizing: border-box;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
}

.content-scroll::-webkit-scrollbar,
.content-scroll::-webkit-scrollbar-thumb,
.content-scroll::-webkit-scrollbar-track {
  width: 0;
  height: 0;
  display: none;
}

.topbar {
  margin-bottom: 16rpx;
}

.hero {
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-entry {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 14rpx;
  border-radius: 16rpx;
  max-width: 100%;
}

.hero-logo {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: block;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  box-shadow: 0 0 0 2rpx rgba(255, 255, 255, 0.12), 0 12rpx 26rpx rgba(0, 0, 0, 0.3);
}

.hero-title-image {
  width: 230rpx;
  margin-top: 14rpx;
  display: block;
}

.hero-title {
  margin-left: 14rpx;
  color: #f7f8fb;
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-subtitle {
  margin-top: 10rpx;
  color: #a6afbe;
  font-size: 26rpx;
}

.hero-pill {
  margin-top: 16rpx;
  min-height: 54rpx;
  border-radius: 10rpx;
  padding: 0 16rpx;
  display: inline-flex;
  align-items: center;
  background: rgba(0, 0, 0, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.hero-pill-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #45c6ff;
  box-shadow: 0 0 10rpx rgba(69, 198, 255, 0.4);
}

.hero-pill-text {
  margin-left: 10rpx;
  color: #b7c0cf;
  font-size: 22rpx;
}

.card {
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  overflow: hidden;
}

.backup-card {
  background: rgba(255, 255, 255, 0.035);
  border-color: rgba(255, 255, 255, 0.11);
}

.export-btn {
  height: 60rpx;
  border-radius: 12rpx;
  padding: 0 18rpx;
  background: rgba(255, 214, 10, 0.16);
  border: 1rpx solid rgba(255, 214, 10, 0.3);
  color: #ffd60a;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.import-btn {
  height: 60rpx;
  border-radius: 12rpx;
  padding: 0 18rpx;
  background: rgba(143, 150, 166, 0.16);
  border: 1rpx solid rgba(143, 150, 166, 0.35);
  color: #d6d9e0;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.export-plain-btn {
  height: 60rpx;
  border-radius: 12rpx;
  padding: 0 18rpx;
  background: rgba(255, 72, 72, 0.12);
  border: 1rpx solid rgba(255, 72, 72, 0.28);
  color: #ff6b6b;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.asset-row {
  height: 98rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}

.asset-row:first-of-type {
  border-top: 0;
}

.asset-label {
  color: #dfe2eb;
  font-size: 26rpx;
}

.asset-value {
  color: #f8fafc;
  font-size: 24rpx;
  font-weight: 600;
}

.asset-row.layer-a {
  background: rgba(255, 255, 255, 0.02);
}

.asset-row.layer-b {
  background: rgba(255, 255, 255, 0.055);
}

.import-hint {
  padding: 10rpx 20rpx 14rpx;
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1.4;
  background: rgba(255, 255, 255, 0.055);
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}

.export-hint {
  padding: 10rpx 20rpx 14rpx;
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1.46;
  background: rgba(255, 255, 255, 0.055);
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}

.asset-right {
  display: flex;
  align-items: center;
}

.asset-sub {
  color: #9ca3b1;
  font-size: 22rpx;
}

.chevron {
  margin-left: 8rpx;
  color: #8f96a6;
  font-size: 30rpx;
  line-height: 1;
}

.setting-row {
  height: 106rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.feedback-row {
  position: relative;
}

.setting-layer-a {
  background: rgba(255, 255, 255, 0.02);
}

.setting-layer-b {
  background: rgba(255, 255, 255, 0.055);
}

.feedback-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: auto;
  width: 260rpx;
  height: 100%;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  z-index: 2;
}

.feedback-overlay::after {
  border: 0 !important;
}

.setting-row + .setting-row {
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.share-gate-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  background: rgba(4, 6, 12, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.share-gate-panel {
  width: 100%;
  max-width: 640rpx;
  border-radius: 28rpx;
  padding: 34rpx 28rpx 30rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(26, 28, 35, 0.98), rgba(16, 17, 23, 0.98));
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 22rpx 60rpx rgba(0, 0, 0, 0.42);
}

.share-gate-title {
  color: #f8fafc;
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
}

.share-gate-desc {
  margin-top: 12rpx;
  color: #d8dce6;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: center;
}

.share-gate-safe-note {
  margin-top: 8rpx;
  color: #8f96a6;
  font-size: 22rpx;
  line-height: 1.4;
  text-align: center;
}

.share-gate-image {
  width: 100%;
  height: 360rpx;
  margin-top: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.03);
}

.share-gate-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.share-gate-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.share-gate-btn::after {
  border: 0 !important;
}

.share-gate-share {
  background: linear-gradient(135deg, #f4f6fb, #e7ecf6);
  color: #14161c;
}

.share-gate-export-ready {
  margin-top: 18rpx;
  width: 100%;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #9b72ff, #ea6ad7);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 34rpx rgba(155, 114, 255, 0.28);
}

.share-gate-export-ready::after {
  border: 0 !important;
}


.setting-title {
  color: #e3e6ee;
  font-size: 27rpx;
}

.danger-row {
  justify-content: center;
  background: rgba(255, 72, 72, 0.08);
}

.danger-title {
  color: #ff9a9a;
  font-weight: 700;
}

.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: flex-end;
  z-index: 40;
}

.sheet {
  width: 100%;
  background: #1f2024;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 24rpx 20rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.sheet-title {
  text-align: center;
  color: #f5f6fa;
  font-size: 30rpx;
  font-weight: 600;
}

.sheet-sub {
  margin-top: 8rpx;
  text-align: center;
  color: #9ca3b1;
  font-size: 22rpx;
}

.dots {
  margin: 18rpx auto;
  width: 70%;
  display: flex;
  justify-content: space-between;
}

.dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 2rpx solid #707784;
}

.dot.filled {
  border-color: #ffffff;
  background: #ffffff;
}

.cooldown {
  text-align: center;
  color: #ff8e8e;
  font-size: 24rpx;
}

.keypad {
  margin-top: 16rpx;
}

.row {
  display: flex;
  margin-bottom: 10rpx;
}

.key {
  margin: 0 8rpx;
  flex: 1;
  height: 82rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.06);
  border-radius: 14rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  color: #f5f6fa;
  transition: transform 120ms ease, background-color 120ms ease, border-color 120ms ease;
}

.key.empty {
  opacity: 0;
}

.key-active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.14);
  border-color: rgba(255, 255, 255, 0.24);
}

.cancel {
  margin-top: 6rpx;
  text-align: center;
  color: #9ca3b1;
  font-size: 26rpx;
}

.import-overlay {
  position: fixed;
  inset: 0;
  background: rgba(4, 6, 12, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.import-modal {
  width: 480rpx;
  padding: 56rpx 40rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(26, 28, 35, 0.98), rgba(16, 17, 23, 0.98));
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.import-spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.12);
  border-top-color: #ffd60a;
  animation: import-spin 0.8s linear infinite;
}

@keyframes import-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.import-check {
  font-size: 48rpx;
  color: #34c759;
  font-weight: 700;
}

.import-cross {
  font-size: 48rpx;
  color: #ff6b6b;
  font-weight: 700;
}

.import-text {
  color: #dfe2eb;
  font-size: 28rpx;
  text-align: center;
  line-height: 1.5;
}
