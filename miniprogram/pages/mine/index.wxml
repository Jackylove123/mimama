<view class="page" style="padding-top: {{pagePaddingTopPx}}px;">
  <scroll-view class="content-scroll" scroll-y="{{mineScrollable}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="content-inner">
      <view class="topbar" style="height: {{navHeightPx}}px;"></view>

    <view class="hero">
      <view class="profile-entry" bindtap="onTapProfile" hover-class="pressable-active" hover-start-time="0" hover-stay-time="28">
        <image class="hero-logo" src="{{userAvatarUrl}}" mode="aspectFill" />
        <view class="hero-title">{{userNickname}}</view>
      </view>
      <view class="hero-subtitle">{{userAuthorized ? '点击进入个人信息' : '点击头像和昵称完成微信授权'}}</view>
      <view class="hero-pill">
        <view class="hero-pill-dot"></view>
        <view class="hero-pill-text">本地加密已就绪 · 只有你能开启</view>
      </view>
    </view>

    <view class="card">
      <view class="asset-row layer-a">
        <view class="asset-label">记录</view>
        <view class="asset-value">{{recordCount}} 条</view>
      </view>
      <view class="asset-row layer-b" bindtap="onTapRecycle" hover-class="pressable-active" hover-start-time="0" hover-stay-time="28">
        <view class="asset-label">回收站</view>
        <view class="asset-right">
          <view class="asset-sub">{{recycleCount}} 条 · 30天保留</view>
          <view class="chevron">›</view>
        </view>
      </view>
      <view class="asset-row layer-a" bindtap="onTapChangePasscode" hover-class="pressable-active" hover-start-time="0" hover-stay-time="28">
        <view class="asset-label">重置启动暗号</view>
        <view class="asset-right">
          <view class="chevron">›</view>
        </view>
      </view>
    </view>

    <view class="card backup-card">
      <view class="asset-row layer-a">
        <view class="asset-label">导入备份</view>
        <view class="import-btn" bindtap="onTapImport" hover-class="{{importing ? '' : 'pressable-active'}}" hover-start-time="0" hover-stay-time="28">
          {{importing ? '导入中' : '导入'}}
        </view>
      </view>
      <view class="import-hint">使用备份档案，一键恢复记录。</view>
      <view class="asset-row layer-a">
        <view class="asset-label">导出备份</view>
        <view class="export-btn" bindtap="onTapExport" hover-class="pressable-active" hover-start-time="0" hover-stay-time="28">导出</view>
      </view>
      <view class="export-hint">
        密麻麻为纯本地存储。受限于小程序系统清理机制，卸载、更换设备或微信清理可能导致数据永久丢失。请务必定期导出备份文件并妥善保存，这是找回记录的唯一途径。
      </view>
    </view>

      <view class="card">
        <view class="setting-row danger-row" bindtap="onTapWipe" hover-class="pressable-active" hover-start-time="0" hover-stay-time="28">
          <view class="setting-title danger-title">抹除密麻麻</view>
        </view>
        <view class="setting-row setting-layer-a feedback-row {{feedbackActive ? 'pressable-active' : ''}}">
          <view class="setting-title">意见反馈</view>
          <view class="chevron">›</view>
          <button
            class="feedback-overlay"
            open-type="feedback"
            bindtouchstart="onFeedbackTouchStart"
            bindtouchend="onFeedbackTouchEnd"
            bindtouchcancel="onFeedbackTouchEnd"
            bindtap="onFeedbackTouchEnd"
          ></button>
        </view>
        <view class="setting-row setting-layer-b" bindtap="onTapAbout" hover-class="pressable-active" hover-start-time="0" hover-stay-time="28">
          <view class="setting-title">关于密麻麻</view>
          <view class="chevron">›</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{showPinSheet}}" class="overlay" bindtap="onTapPinClose">
    <view class="sheet" catchtap="noop">
      <view class="sheet-title">对一下启动暗号</view>
      <view class="sheet-sub">暗号正确后继续当前操作</view>
      <view class="dots">
        <view wx:for="{{pinSlots}}" wx:key="*this" class="dot {{index < pinDigits.length ? 'filled' : ''}}"></view>
      </view>
      <view wx:if="{{cooldownSeconds > 0}}" class="cooldown">暗号冷却中，{{cooldownSeconds}} 秒后再试</view>

      <view class="keypad">
        <view wx:for="{{keypadRows}}" wx:key="index" class="row">
          <view
            wx:for="{{item}}"
            wx:key="*this"
            class="key {{item === '' ? 'empty' : ''}}"
            data-key="{{item}}"
            bindtap="onTapPinKey"
            hover-class="{{item ? 'pressable-active' : ''}}"
            hover-start-time="0"
            hover-stay-time="28"
          >
            <text wx:if="{{item === 'del'}}">删除</text>
            <text wx:elif="{{item}}">{{item}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <app-dialog
    visible="{{dialog.visible}}"
    title="{{dialog.title}}"
    content="{{dialog.content}}"
    showCancel="{{dialog.showCancel}}"
    maskClosable="{{dialog.maskClosable}}"
    cancelText="{{dialog.cancelText}}"
    confirmText="{{dialog.confirmText}}"
    danger="{{dialog.danger}}"
    bindconfirm="onDialogConfirm"
    bindcancel="onDialogCancel"
  />
</view>
