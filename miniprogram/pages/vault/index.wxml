<view class="page">
  <view class="search" bindtap="onTapSearch">
    <text class="search-placeholder">搜索账号 / 网站 / 备注</text>
    <text class="search-action">搜索</text>
  </view>

  <view class="tabs">
    <view class="tab {{filterTab === 'recent' ? 'active' : ''}}" data-tab="recent" bindtap="onChangeFilter">最近使用</view>
    <view class="tab {{filterTab === 'favorite' ? 'active' : ''}}" data-tab="favorite" bindtap="onChangeFilter">收藏</view>
  </view>

  <view wx:if="{{loading}}" class="hint">加载中...</view>

  <view wx:elif="{{cards.length === 0}}" class="hint">{{emptyText}}</view>

  <view wx:else class="list">
    <view wx:for="{{cards}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="onOpenDetail">
      <view class="avatar">{{item.title.slice(0, 1)}}</view>
      <view class="main">
        <view class="row">
          <text class="title">{{item.title}}</text>
          <text wx:if="{{item.isFavorite}}" class="fav">★</text>
        </view>
        <view class="account">{{item.account}}</view>
        <view class="meta">{{item.maskedPassword}} · {{item.relativeUpdatedAt}}</view>
      </view>
    </view>
  </view>

  <view class="fab" bindtap="onTapCreate">+</view>
</view>
