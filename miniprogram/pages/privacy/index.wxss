.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1b1c20, #121317 58%);
  padding: 24rpx 28rpx calc(34rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.doc {
  color: #d3d9e5;
}

.doc-title {
  color: #f8fafc;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
}

.meta {
  margin-top: 10rpx;
  color: #9ca3b1;
  font-size: 24rpx;
  line-height: 1.5;
}

.section {
  margin-top: 24rpx;
}

.section-title {
  margin-top: 26rpx;
  color: #eef2f8;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.45;
}

.paragraph {
  margin-top: 12rpx;
  color: #d3d9e5;
  font-size: 28rpx;
  line-height: 1.8;
}

.quote {
  margin-top: 12rpx;
  padding: 0 0 0 16rpx;
  border-left: 4rpx solid rgba(69, 198, 255, 0.6);
  color: #e3f5ff;
  font-size: 28rpx;
  line-height: 1.8;
}

.list-item {
  margin-top: 12rpx;
  color: #d3d9e5;
  font-size: 28rpx;
  line-height: 1.8;
}

.notice {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-left: 4rpx solid rgba(255, 126, 126, 0.6);
  color: #ffd5d5;
  font-size: 27rpx;
  line-height: 1.7;
  background: rgba(255, 98, 98, 0.08);
}
