.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1b1c20, #121317 58%);
  padding: 28rpx 26rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero-card {
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.05);
  padding: 30rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  border-radius: 999rpx;
  line-height: 1;
}

.avatar-btn::after {
  border: 0 !important;
}

.avatar {
  width: 116rpx;
  height: 116rpx;
  border-radius: 29rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  box-shadow: 0 0 0 2rpx rgba(255, 255, 255, 0.12), 0 16rpx 34rpx rgba(0, 0, 0, 0.3);
}

.avatar-tip {
  margin-top: 16rpx;
  color: #9ca3b1;
  font-size: 23rpx;
}

.info-card {
  margin-top: 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.05);
  overflow: hidden;
}

.info-row {
  min-height: 98rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.info-row + .info-row {
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.label {
  color: #dfe2eb;
  font-size: 27rpx;
}

.value {
  max-width: 68%;
  color: #9ca3b1;
  font-size: 26rpx;
  text-align: right;
  word-break: break-all;
}

.value-input {
  width: 360rpx;
  height: 98rpx;
  color: #e9edf6;
  font-size: 26rpx;
  text-align: right;
}

.motto-block {
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  padding: 20rpx 22rpx;
}

.motto-input {
  margin-top: 10rpx;
  width: 100%;
  min-height: 148rpx;
  color: #e9edf6;
  font-size: 25rpx;
  line-height: 1.6;
}

.save-btn {
  margin-top: 20rpx;
  height: 92rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.07);
  color: #f3f5fb;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
