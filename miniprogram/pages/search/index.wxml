<view class="page">
  <view class="search-box">
    <input
      class="input"
      value="{{query}}"
      placeholder="搜索标题 / 账号 / 网站 / 备注"
      bindinput="onInput"
      confirm-type="search"
    />
    <text wx:if="{{query}}" class="clear" bindtap="onClear">清空</text>
  </view>

  <view wx:if="{{loading}}" class="hint">搜索中...</view>
  <view wx:elif="{{cards.length === 0}}" class="hint">没有匹配结果</view>

  <view wx:else class="list">
    <view wx:for="{{cards}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="onOpenDetail">
      <view class="title">{{item.title}}</view>
      <view class="account">{{item.account}}</view>
      <view class="meta">{{item.maskedPassword}} · {{item.updatedText}}</view>
    </view>
  </view>
</view>
