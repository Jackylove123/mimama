.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1b1c20, #121317 58%);
  padding: 24rpx;
  box-sizing: border-box;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
}

.card {
  margin-top: 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  padding: 18rpx;
}

.label {
  color: #a9afbc;
  font-size: 24rpx;
}

.value {
  margin-top: 8rpx;
  color: #f5f6fa;
  font-size: 28rpx;
  word-break: break-all;
}

.btn {
  margin-top: 12rpx;
  height: 62rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #f5f6fa;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
}

.row {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
}

.half {
  width: 48%;
  height: 62rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #f5f6fa;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
}

.actions {
  margin-top: 16rpx;
}

.half.danger {
  background: rgba(220, 38, 38, 0.2);
  color: #ff8e8e;
}
