.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1b1c20, #121317 58%);
  padding: 24rpx 24rpx calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 18rpx;
  padding: 22rpx;
}

.label {
  margin-top: 18rpx;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: #a9afbc;
}

.input {
  height: 72rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.06);
  padding: 0 14rpx;
  font-size: 28rpx;
  color: #f5f6fa;
}

.category-picker {
  height: 72rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.06);
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.category-text {
  font-size: 27rpx;
  color: #f5f6fa;
}

.category-arrow {
  font-size: 34rpx;
  line-height: 1;
  color: #aab2c1;
}

.category-hint {
  margin-top: 8rpx;
  color: #8891a3;
  font-size: 22rpx;
}

.password-field {
  position: relative;
}

.password-input {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding-right: 88rpx;
}

.password-visibility {
  position: absolute;
  right: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 120ms ease, background-color 120ms ease, border-color 120ms ease;
}

.password-visibility-active {
  transform: translateY(-50%) scale(0.94);
}

.password-visibility.showing {
  background: rgba(255, 255, 255, 0.16);
  border-color: rgba(248, 250, 252, 0.5);
}

.eye-icon {
  position: relative;
  width: 32rpx;
  height: 20rpx;
  border: 3rpx solid #c6ccd8;
  border-radius: 26rpx / 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.eye-pupil {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #c6ccd8;
}

.password-visibility.showing .eye-icon {
  border-color: #f6f8fb;
}

.password-visibility.showing .eye-pupil {
  background: #f6f8fb;
}

.eye-slash {
  position: absolute;
  width: 38rpx;
  height: 3rpx;
  border-radius: 3rpx;
  background: #c6ccd8;
  transform: rotate(-32deg);
}

.input::placeholder,
.textarea::placeholder {
  color: #8e919a;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.06);
  padding: 14rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #f5f6fa;
}

.small-btn {
  margin-top: 10rpx;
  margin-bottom: 8rpx;
  width: 180rpx;
  height: 60rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #f5f6fa;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
}

.save-btn {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  height: 86rpx;
  border-radius: 18rpx;
  background: #f2f3f7;
  color: #141418;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.28);
  transition: transform 120ms ease, filter 120ms ease, opacity 120ms ease, box-shadow 120ms ease;
}

.save-btn-active {
  transform: scale(0.985);
  filter: brightness(0.9);
  box-shadow: 0 6rpx 14rpx rgba(0, 0, 0, 0.22);
}

.save-btn.is-saving {
  opacity: 0.72;
  filter: grayscale(0.2);
  box-shadow: 0 6rpx 14rpx rgba(0, 0, 0, 0.2);
}

.footer-actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 14rpx;
}

.action-btn {
  height: 86rpx;
  border-radius: 18rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  transition: transform 120ms ease, filter 120ms ease, opacity 120ms ease, box-shadow 120ms ease;
}

.footer-btn-active {
  transform: scale(0.985);
  filter: brightness(0.95);
  box-shadow: 0 6rpx 14rpx rgba(0, 0, 0, 0.22);
}

.delete-btn-inline {
  flex: 1;
  background: rgba(239, 68, 68, 0.18);
  color: #fca5a5;
  border: 1rpx solid rgba(239, 68, 68, 0.42);
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.22);
}

.delete-btn-inline.is-loading {
  opacity: 0.72;
  filter: grayscale(0.2);
}

.save-btn-inline {
  flex: 1;
  background: #f2f3f7;
  color: #141418;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.28);
}

.save-btn-inline.is-saving {
  opacity: 0.72;
  filter: grayscale(0.2);
  box-shadow: 0 6rpx 14rpx rgba(0, 0, 0, 0.2);
}

.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 60;
  background: rgba(7, 8, 11, 0.55);
  display: flex;
  align-items: flex-end;
}

.sheet-panel {
  width: 100%;
  border-radius: 28rpx 28rpx 0 0;
  background: linear-gradient(160deg, #21242c, #17191f);
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  padding: 20rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
}

.sheet-title {
  text-align: center;
  color: #f6f8fb;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.sheet-item {
  height: 88rpx;
  border-radius: 14rpx;
  padding: 0 26rpx;
  margin-bottom: 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.04);
  color: #cfd5e1;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  font-size: 28rpx;
}

.sheet-item-label {
  font-size: 28rpx;
  line-height: 1;
}

.sheet-item.active {
  border-color: rgba(248, 250, 252, 0.82);
  color: #f8fafc;
}

.sheet-cancel {
  height: 88rpx;
  border-radius: 14rpx;
  margin-top: 4rpx;
  color: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.1);
}
