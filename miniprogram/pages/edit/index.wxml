<view class="page">
  <view class="card">
    <view class="label">标题</view>
    <input class="input" data-field="title" value="{{title}}" placeholder="例如：微信 / 邮箱" bindinput="onInput" />

    <view class="label">分类</view>
    <view class="category-picker" bindtap="onOpenCategorySheet" hover-class="pressable-active" hover-start-time="0" hover-stay-time="28">
      <view class="category-text">{{categoryLabel}}</view>
      <view class="category-arrow">›</view>
    </view>

    <view class="label">账号</view>
    <input class="input" data-field="account" value="{{account}}" placeholder="手机号 / 邮箱 / 用户名" bindinput="onInput" />

    <view class="label">密码</view>
    <view class="password-field">
      <input
        class="input password-input"
        data-field="password"
        value="{{password}}"
        password="{{!showPassword}}"
        placeholder="请输入密码"
        bindinput="onInput"
      />
      <view
        class="password-visibility {{showPassword ? 'showing' : 'hiding'}}"
        bindtap="onTogglePasswordVisibility"
        hover-class="pressable-active"
        hover-start-time="0"
        hover-stay-time="28"
      >
        <view class="eye-icon">
          <view class="eye-pupil"></view>
          <view wx:if="{{!showPassword}}" class="eye-slash"></view>
        </view>
      </view>
    </view>
    <view class="small-btn" bindtap="onGeneratePassword" hover-class="pressable-active" hover-start-time="0" hover-stay-time="28">随机生成</view>

    <view class="label">备注</view>
    <textarea class="textarea" data-field="note" value="{{note}}" maxlength="{{noteMaxLength}}" placeholder="可选" bindinput="onInput" />
  </view>

  <view wx:if="{{isEdit}}" class="footer-actions">
    <view
      class="action-btn delete-btn-inline {{deleting ? 'is-loading' : ''}}"
      bindtap="onTapDelete"
      hover-class="{{saving || deleting ? '' : 'footer-btn-active'}}"
      hover-start-time="0"
      hover-stay-time="28"
    >
      {{deleting ? '删除中...' : '删除'}}
    </view>
    <view
      class="action-btn save-btn-inline {{saving ? 'is-saving' : ''}}"
      bindtap="onTapSave"
      hover-class="{{saving || deleting ? '' : 'footer-btn-active'}}"
      hover-start-time="0"
      hover-stay-time="28"
    >
      {{saving ? '保存中...' : '保存'}}
    </view>
  </view>

  <view
    wx:else
    class="save-btn {{saving ? 'is-saving' : ''}}"
    bindtap="onTapSave"
    hover-class="{{saving ? '' : 'light-press-active'}}"
    hover-start-time="0"
    hover-stay-time="28"
  >
    {{saving ? '保存中...' : '保存'}}
  </view>

  <view wx:if="{{categorySheetVisible}}" class="sheet-mask" bindtap="onCloseCategorySheet">
    <view class="sheet-panel" catchtap="noop">
      <view class="sheet-title">选择分类</view>
      <view
        wx:for="{{categoryOptions}}"
        wx:key="key"
        class="sheet-item {{item.key === category ? 'active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onSelectCategory"
        hover-class="pressable-active"
        hover-start-time="0"
        hover-stay-time="28"
      >
        <view class="sheet-item-label">{{item.label}}</view>
      </view>
      <view class="sheet-cancel" bindtap="onCloseCategorySheet" hover-class="pressable-active" hover-start-time="0" hover-stay-time="28">取消</view>
    </view>
  </view>
</view>
