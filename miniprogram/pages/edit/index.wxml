<view class="page">
  <view class="card">
    <view class="label">标题</view>
    <input class="input" data-field="title" value="{{title}}" placeholder="例如：微信" bindinput="onInput" />

    <view class="label">账号</view>
    <input class="input" data-field="account" value="{{account}}" placeholder="手机号 / 邮箱 / 用户名" bindinput="onInput" />

    <view class="label">密码</view>
    <input class="input" data-field="password" value="{{password}}" password="{{true}}" placeholder="请输入密码" bindinput="onInput" />
    <view class="small-btn" bindtap="onGeneratePassword">随机生成密码</view>

    <view class="label">网站</view>
    <input class="input" data-field="website" value="{{website}}" placeholder="https://example.com" bindinput="onInput" />

    <view class="label">备注</view>
    <textarea class="textarea" data-field="note" value="{{note}}" placeholder="可选备注" bindinput="onInput" />

    <view class="switch-row">
      <text>收藏</text>
      <switch checked="{{isFavorite}}" color="#176B87" bindchange="onChangeFavorite" />
    </view>
  </view>

  <view class="save-btn" bindtap="onTapSave">{{saving ? '保存中...' : '保存'}}</view>
</view>
