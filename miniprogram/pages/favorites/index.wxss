.page {
  min-height: 100vh;
  background: #f6f8fa;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hint {
  margin-top: 120rpx;
  text-align: center;
  color: #64748b;
  font-size: 26rpx;
}

.list {
  margin-top: 10rpx;
}

.card {
  margin-bottom: 16rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e3e8ef;
  padding: 18rpx;
  display: flex;
  align-items: center;
}

.main {
  flex: 1;
}

.title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 600;
}

.account {
  margin-top: 8rpx;
  color: #475569;
  font-size: 26rpx;
}

.meta {
  margin-top: 6rpx;
  color: #94a3b8;
  font-size: 24rpx;
}

.unstar {
  color: #176b87;
  font-size: 24rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(23, 107, 135, 0.08);
}
